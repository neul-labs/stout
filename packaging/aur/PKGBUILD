# Maintainer: Neul Labs <stout@neul-labs.com>
# Contributor: Neul Labs <stout@neul-labs.com>

pkgname=stout
pkgver=0.1.0
pkgrel=1
pkgdesc="Fast, Rust-based Homebrew-compatible package manager"
arch=('x86_64' 'aarch64')
url="https://github.com/neul-labs/stout"
license=('MIT')
depends=('gcc-libs')
makedepends=('cargo')
optdepends=(
    'bash-completion: for bash shell completions'
    'zsh-completions: for zsh shell completions'
    'fish: for fish shell completions'
)
provides=('stout')
conflicts=('stout-bin' 'stout-git')
source=("$pkgname-$pkgver.tar.gz::https://github.com/neul-labs/$pkgname/archive/v$pkgver.tar.gz")
sha256sums=('PLACEHOLDER_SHA256')

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    export STOUT_GEN_MAN=1
    cargo build --release --locked
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --locked
}

package() {
    cd "$pkgname-$pkgver"

    # Install binary
    install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"

    # Install license
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Install documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"

    # Generate and install shell completions
    install -dm755 "$pkgdir/usr/share/bash-completion/completions"
    install -dm755 "$pkgdir/usr/share/zsh/site-functions"
    install -dm755 "$pkgdir/usr/share/fish/vendor_completions.d"

    "$pkgdir/usr/bin/$pkgname" completions bash > "$pkgdir/usr/share/bash-completion/completions/$pkgname"
    "$pkgdir/usr/bin/$pkgname" completions zsh > "$pkgdir/usr/share/zsh/site-functions/_$pkgname"
    "$pkgdir/usr/bin/$pkgname" completions fish > "$pkgdir/usr/share/fish/vendor_completions.d/$pkgname.fish"

    # Install man pages
    install -dm755 "$pkgdir/usr/share/man/man1"
    local man_dir=$(find target/release/build -name "stout-*" -type d -path "*/out" | head -1)/man
    if [ -d "$man_dir" ]; then
        install -m644 "$man_dir"/*.1 "$pkgdir/usr/share/man/man1/"
    fi
}
